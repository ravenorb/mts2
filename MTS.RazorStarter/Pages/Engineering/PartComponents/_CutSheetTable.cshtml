@model IReadOnlyList<MTS.RazorStarter.Pages.Engineering.FramePartModel.CutSheetRowViewModel>

<section>
    <h3 class="panel-title">Cut Sheets</h3>

    @if (Model.Count == 0)
    {
        <div class="empty-state">No cut sheets available.</div>
    }
    else
    {
        <table class="cutsheet-table">
            <thead>
                <tr>
                    <th>File Name</th>
                    <th>Type</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var cutSheet in Model)
            {
                <tr>
                    <td>
                        @if (string.IsNullOrWhiteSpace(cutSheet.ViewPath))
                        {
                            <span>@cutSheet.FileName</span>
                        }
                        else
                        {
                            <a class="cutsheet-link" href="@cutSheet.ViewPath" target="_blank" rel="noopener noreferrer">@cutSheet.FileName</a>
                        }
                    </td>
                    <td>@cutSheet.Type</td>
                    <td>
                        @if (string.IsNullOrWhiteSpace(cutSheet.ViewPath))
                        {
                            <span style="color:#94a3b8;">Unavailable</span>
                        }
                        else
                        {
                            <a class="part-btn" href="@cutSheet.ViewPath" target="_blank" rel="noopener noreferrer">View</a>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
</section>
