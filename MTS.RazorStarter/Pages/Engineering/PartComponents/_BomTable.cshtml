@using Mts.Domain
@model MTS.RazorStarter.Models.FramePartViewModel

@if (Model.BomRows.Count == 0)
{
    <div class="empty-state">No BOM items linked.</div>
}
else
{
    <div class="bom-table-wrap">
        <table class="bom-table">
            <thead>
                <tr>
                    <th>Source</th>
                    <th>Find No</th>
                    <th>Item No</th>
                    <th>Description</th>
                    <th>Rev</th>
                    <th>Qty</th>
                    <th>Role</th>
                    <th>Notes</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.BomRows)
                {
                    var rowClass = row.SourceType == BomSourceType.Manual ? "bom-row-manual" : string.Empty;
                    <tr class="@rowClass">
                        <td>
                            @if (row.SourceType == BomSourceType.Manual)
                            {
                                <span title="Manual row">✏️</span>
                            }
                            else if (row.SourceType == BomSourceType.Csv)
                            {
                                <span title="CSV imported row">📊</span>
                            }
                            else
                            {
                                <span title="Drawing generated row">📄</span>
                            }
                        </td>
                        <td>
                            <input form="edit-bom-@row.Id" name="EditRow.FindNo" value="@row.FindNo" />
                        </td>
                        <td class="bom-item-cell">
                            <input form="edit-bom-@row.Id" name="EditRow.ItemNo" value="@row.ItemNo" required />
                        </td>
                        <td>
                            <input form="edit-bom-@row.Id" name="EditRow.Description" value="@row.Title" />
                        </td>
                        <td>@row.RevisionCode</td>
                        <td>
                            <input form="edit-bom-@row.Id" type="number" step="0.0001" min="0.0001" name="EditRow.Qty" value="@row.Qty" required />
                        </td>
                        <td>
                            <select form="edit-bom-@row.Id" name="EditRow.BomRole">
                                <option selected="@(row.BomRole == "Component")" value="Component">Component</option>
                                <option selected="@(row.BomRole == "Subassembly")" value="Subassembly">Subassembly</option>
                                <option selected="@(row.BomRole == "Hardware")" value="Hardware">Hardware</option>
                                <option selected="@(row.BomRole == "Consumable")" value="Consumable">Consumable</option>
                            </select>
                        </td>
                        <td>
                            <input form="edit-bom-@row.Id" name="EditRow.Notes" value="@row.Notes" />
                        </td>
                        <td class="bom-actions-cell">
                            <form id="edit-bom-@row.Id" method="post" asp-page-handler="SaveBomRow" asp-route-itemNo="@Model.ItemNo">
                                <input type="hidden" name="EditRow.Id" value="@row.Id" />
                                <input type="hidden" name="EditRow.ParentRevisionId" value="@Model.CurrentRevisionId" />
                                <button type="submit" class="part-btn">Save</button>
                            </form>
                            <form method="post" asp-page-handler="DeleteBomRow" asp-route-itemNo="@Model.ItemNo" asp-route-bomId="@row.Id" onsubmit="return confirm('Delete BOM row?');">
                                <button type="submit" class="part-btn">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="bom-add-row-panel">
    <h4>Add BOM row</h4>
    <form method="post" asp-page-handler="SaveBomRow" asp-route-itemNo="@Model.ItemNo" class="bom-add-row-form">
        <input type="hidden" name="EditRow.ParentRevisionId" value="@Model.CurrentRevisionId" />
        <input name="EditRow.FindNo" placeholder="Find No" />
        <input name="EditRow.ItemNo" placeholder="Item No" required />
        <input name="EditRow.Description" placeholder="Description" required />
        <input name="EditRow.Qty" type="number" step="0.0001" min="0.0001" value="1" required />
        <input name="EditRow.BomRole" value="Component" />
        <input name="EditRow.Notes" placeholder="Notes" />
        <button type="submit" class="part-btn part-btn-primary">Add Row</button>
    </form>
</div>

<div class="bom-upload-panel">
    <h4>eBOM generation and CSV override</h4>
    <form method="post" asp-page-handler="GenerateBom" asp-route-itemNo="@Model.ItemNo" class="bom-upload-form">
        <button type="submit" class="part-btn part-btn-primary">Generate from Drawing</button>
    </form>

    <p class="small-muted">CSV columns: FindNo, ItemNo, Description, Qty, Notes.</p>
    <form method="post" enctype="multipart/form-data" asp-page-handler="ImportCsv" asp-route-itemNo="@Model.ItemNo" class="bom-upload-form">
        <input type="file" name="BomUpload" accept=".csv,.txt" required />
        <button type="submit" class="part-btn part-btn-primary">Import CSV</button>
    </form>
</div>
