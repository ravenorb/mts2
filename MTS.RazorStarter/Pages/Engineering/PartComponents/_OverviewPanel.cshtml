@model MTS.RazorStarter.Models.FramePartViewModel

<section>
    <h3 class="panel-title">Part Summary</h3>
    <div class="overview-grid">
        <div class="overview-item">
            <div class="overview-label">Item No</div>
            <div class="overview-value">@Model.ItemNo</div>
        </div>
        <div class="overview-item">
            <div class="overview-label">Title</div>
            <div class="overview-value">@Model.Title</div>
        </div>
        <div class="overview-item">
            <div class="overview-label">Revision</div>
            <div class="overview-value">@Model.CurrentRevisionCode</div>
        </div>
        <div class="overview-item">
            <div class="overview-label">Lifecycle State</div>
            <div class="overview-value">@Model.LifecycleState</div>
        </div>
        <div class="overview-item">
            <div class="overview-label">Created</div>
            <div class="overview-value">@Model.CreatedAt.ToString("yyyy-MM-dd")</div>
        </div>
        <div class="overview-item">
            <div class="overview-label">Updated</div>
            <div class="overview-value">@Model.UpdatedAt.ToString("yyyy-MM-dd")</div>
        </div>
    </div>
</section>
