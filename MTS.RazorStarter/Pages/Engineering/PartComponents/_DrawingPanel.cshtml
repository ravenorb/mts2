@model MTS.RazorStarter.Models.FramePartViewModel

<section>
    <h3 class="panel-title">Drawing Viewer</h3>

    <form method="post" enctype="multipart/form-data" asp-page-handler="UploadDrawing" class="drawing-upload-form">
        <input type="file" name="DrawingUpload" accept=".pdf,application/pdf" required />
        <input type="text" name="DrawingRevisionCode" placeholder="Revision code (optional)" value="@Model.CurrentRevisionCode" />
        <button type="submit" class="part-btn part-btn-primary">Upload Drawing</button>
    </form>

    @if (Model.HasDrawing && !string.IsNullOrWhiteSpace(Model.DrawingOpenUrl))
    {
        <div class="drawing-toolbar" data-drawing-toolbar>
            <div class="drawing-toolbar-group">
                <button type="button" class="part-btn" data-zoom-out>−</button>
                <button type="button" class="part-btn" data-zoom-in>+</button>
                <button type="button" class="part-btn" data-zoom-reset>Reset</button>
                <span class="zoom-level" data-zoom-level>100%</span>
            </div>
            <div class="drawing-toolbar-group">
                <a class="part-btn" href="@Model.DrawingOpenUrl" target="_blank" rel="noopener noreferrer">Open</a>
                @if (!string.IsNullOrWhiteSpace(Model.DrawingDownloadUrl))
                {
                    <a class="part-btn part-btn-primary" href="@Model.DrawingDownloadUrl">Download</a>
                }
            </div>
        </div>

        <div class="drawing-viewer-outer" data-drawing-viewport>
            <div class="drawing-viewer-inner" data-drawing-scaled>
                <iframe class="drawing-frame" src="@Model.DrawingOpenUrl" title="Drawing - @Model.DrawingFileName"></iframe>
            </div>
        </div>
    }
    else
    {
        <div class="empty-state">No drawing uploaded.</div>
    }
</section>
