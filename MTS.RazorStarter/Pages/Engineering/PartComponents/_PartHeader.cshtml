@model MTS.RazorStarter.Models.FramePartViewModel
@{
    var isReleased = string.Equals(Model.CurrentRevisionStatus, "Released", StringComparison.OrdinalIgnoreCase);
}

<header class="part-card part-header">
    <div>
        <h1 class="part-id">@Model.ItemNo</h1>
        <p class="part-title">@Model.Title</p>
        <div class="part-meta-line">
            <span class="badge badge-revision">Revision @Model.CurrentRevisionCode</span>
            <span class="badge @(isReleased ? "badge-status-released" : "badge-status-draft")">@Model.CurrentRevisionStatus</span>
        </div>
    </div>
    <div class="part-action-row">
        <a class="part-btn" href="#">Upload Drawing</a>
        <a class="part-btn part-btn-primary" href="#">Upload Cut Sheet</a>
    </div>
</header>
