@page "/Engineering/FramePart"
@model MTS.RazorStarter.Pages.Engineering.FramePartIndexModel
@{
    ViewData["Title"] = "Frame Parts";
}

<section class="part-index-page">
    <div class="part-card mts-panel part-index-header">
        <h2>Frame Parts</h2>
        <a class="mts-btn mts-btn-primary" href="/Engineering/FramePart/Create">Add Frame Part</a>
    </div>

    <form class="part-index-filters" method="get">
        <input type="text" name="search" placeholder="Search item no or title..." value="@Model.Search" />
        <select name="state">
            <option value="">All States</option>
            <option value="Active" selected="@(Model.State == "Active" ? "selected" : null)">Active</option>
            <option value="Inactive" selected="@(Model.State == "Inactive" ? "selected" : null)">Inactive</option>
        </select>
        <div>
            <input type="hidden" name="sort" value="@Model.Sort" />
            <input type="hidden" name="dir" value="@Model.Dir" />
            <button class="mts-btn mts-btn-primary" type="submit">Filter</button>
        </div>
    </form>

    @if (Model.FrameParts.Count == 0)
    {
        <section class="part-card mts-panel part-index-empty">
            <p>No frame parts found.</p>
            <a class="mts-btn mts-btn-primary" href="/Engineering/FramePart/Create">Create First Frame Part</a>
        </section>
    }
    else
    {
        <section class="part-card mts-panel">
            <div class="part-index-table-wrap">
                <table class="part-index-table">
                    <thead>
                        <tr>
                            <th>
                                <a asp-page="/Engineering/FramePartIndex"
                                   asp-route-search="@Model.Search"
                                   asp-route-state="@Model.State"
                                   asp-route-sort="ItemNo"
                                   asp-route-dir="@Model.ToggleDir("ItemNo")"
                                   asp-route-page="1">Item No</a>
                            </th>
                            <th>
                                <a asp-page="/Engineering/FramePartIndex"
                                   asp-route-search="@Model.Search"
                                   asp-route-state="@Model.State"
                                   asp-route-sort="Title"
                                   asp-route-dir="@Model.ToggleDir("Title")"
                                   asp-route-page="1">Title</a>
                            </th>
                            <th>Revision</th>
                            <th>State</th>
                            <th>
                                <a asp-page="/Engineering/FramePartIndex"
                                   asp-route-search="@Model.Search"
                                   asp-route-state="@Model.State"
                                   asp-route-sort="Updated"
                                   asp-route-dir="@Model.ToggleDir("Updated")"
                                   asp-route-page="1">Updated</a>
                            </th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var part in Model.FrameParts)
                        {
                            var isActive = string.Equals(part.LifecycleState, "Active", StringComparison.OrdinalIgnoreCase);
                            <tr>
                                <td>@part.ItemNo</td>
                                <td>@part.Title</td>
                                <td>@(part.CurrentRevision ?? "-")</td>
                                <td>
                                    <span class="mts-badge @(isActive ? "mts-badge-success" : "mts-badge-warning")">@part.LifecycleState</span>
                                </td>
                                <td>@part.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>
                                    <a class="mts-btn mts-btn-secondary" href="/Engineering/FramePart/@part.ItemNo">Open</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <div class="part-card mts-panel part-index-pagination">
            <span>Page @Model.Page of @Model.TotalPages (@Model.TotalCount total)</span>
            <div class="part-index-pagination-links">
                @if (Model.HasPreviousPage)
                {
                    <a class="mts-btn mts-btn-secondary"
                       asp-page="/Engineering/FramePartIndex"
                       asp-route-search="@Model.Search"
                       asp-route-state="@Model.State"
                       asp-route-sort="@Model.Sort"
                       asp-route-dir="@Model.Dir"
                       asp-route-page="@(Model.Page - 1)">Previous</a>
                }
                @if (Model.HasNextPage)
                {
                    <a class="mts-btn mts-btn-secondary"
                       asp-page="/Engineering/FramePartIndex"
                       asp-route-search="@Model.Search"
                       asp-route-state="@Model.State"
                       asp-route-sort="@Model.Sort"
                       asp-route-dir="@Model.Dir"
                       asp-route-page="@(Model.Page + 1)">Next</a>
                }
            </div>
        </div>
    }
</section>
