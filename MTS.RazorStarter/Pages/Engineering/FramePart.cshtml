@page "{itemNo}"
@model MTS.RazorStarter.Pages.Engineering.FramePartModel
@{
    ViewData["Title"] = $"Frame Part {Model.FramePart?.ItemNo}";
}

@if (Model.FramePart == null)
{
    <section class="part-empty-state">
        <h2>Part not found</h2>
        <p>The requested frame part is unavailable.</p>
    </section>
}
else
{
    <section class="part-detail-page">
        <partial name="PartComponents/_PartHeader" model="Model.FramePart" />

        <div class="part-detail-grid">
            <div class="part-main-column">
                <partial name="PartComponents/_PartTabs" model="Model.FramePart" />
            </div>
            <aside class="part-sidebar-column">
                <partial name="PartComponents/_SidebarPanel" model="Model.FramePart" />
            </aside>
        </div>
    </section>
}

<style>
    .part-detail-page { display: grid; gap: 1rem; color: #0f172a; }
    .part-card { background: #fff; border: 1px solid #e2e8f0; border-radius: 12px; box-shadow: 0 4px 14px rgba(15, 23, 42, 0.05); }
    .part-header { padding: 1.25rem 1.5rem; display: flex; justify-content: space-between; gap: 1rem; align-items: start; }
    .part-id { margin: 0; font-size: 1.9rem; font-weight: 700; letter-spacing: -0.02em; }
    .part-title { margin: 0.3rem 0 0; color: #475569; font-size: 1rem; }
    .part-meta-line { display: flex; gap: 0.5rem; align-items: center; margin-top: 0.7rem; }
    .badge { border-radius: 999px; padding: 0.2rem 0.65rem; font-size: 0.78rem; font-weight: 600; }
    .badge-revision { background: #e0f2fe; color: #0c4a6e; }
    .badge-status-released { background: #dcfce7; color: #166534; }
    .badge-status-draft { background: #fef3c7; color: #92400e; }
    .part-action-row { display: flex; gap: 0.6rem; flex-wrap: wrap; }
    .part-btn { border: 1px solid #cbd5e1; background: #fff; color: #0f172a; border-radius: 9px; padding: 0.48rem 0.9rem; font-size: 0.9rem; font-weight: 500; text-decoration: none; cursor: pointer; }
    .part-btn-primary { background: #0f172a; color: #fff; border-color: #0f172a; }

    .part-detail-grid { display: grid; grid-template-columns: minmax(0, 1fr) 300px; gap: 1rem; }
    .part-main-column, .part-sidebar-column { min-width: 0; }

    .part-tabs-nav { display: flex; gap: 0.25rem; border-bottom: 1px solid #e2e8f0; padding: 0.6rem 0.8rem; overflow-x: auto; }
    .part-tab-trigger { border: 0; background: transparent; border-radius: 8px; padding: 0.48rem 0.8rem; color: #475569; font-weight: 500; cursor: pointer; }
    .part-tab-trigger.active { background: #e2e8f0; color: #0f172a; }
    .part-tab-content { padding: 1rem; display: none; }
    .part-tab-content.active { display: block; }

    .panel-title { margin: 0 0 0.75rem; font-size: 1rem; font-weight: 600; }
    .overview-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 0.7rem; }
    .overview-item { border: 1px solid #e2e8f0; border-radius: 10px; padding: 0.7rem; background: #f8fafc; }
    .overview-label { color: #64748b; font-size: 0.78rem; }
    .overview-value { font-weight: 600; margin-top: 0.2rem; }
    .overview-bom-section { margin-top: 1rem; }

    .drawing-toolbar { display: flex; justify-content: space-between; gap: 0.75rem; align-items: center; margin-bottom: 0.75rem; flex-wrap: wrap; }
    .drawing-toolbar-group { display: flex; gap: 0.45rem; align-items: center; }
    .zoom-level { font-size: 0.85rem; color: #334155; min-width: 56px; text-align: center; }
    .drawing-viewer-outer { width: 100%; height: 680px; overflow: auto; border: 1px solid #cbd5e1; border-radius: 10px; background: #f8fafc; }
    .drawing-viewer-inner { width: 100%; min-height: 100%; transform-origin: top left; }
    .drawing-frame { width: 100%; min-height: 680px; border: 0; background: #fff; }
    .empty-state { border: 1px dashed #cbd5e1; border-radius: 10px; padding: 1rem; color: #64748b; }

    .cutsheet-table { width: 100%; border-collapse: collapse; }
    .cutsheet-table th, .cutsheet-table td { text-align: left; padding: 0.65rem 0.5rem; border-bottom: 1px solid #e2e8f0; }
    .cutsheet-table th { color: #64748b; font-size: 0.82rem; font-weight: 600; }
    .cutsheet-link { color: #0f172a; font-weight: 500; text-decoration: none; }

    .bom-table-wrap { overflow: auto; border: 1px solid #e2e8f0; border-radius: 10px; }
    .bom-table { width: 100%; border-collapse: collapse; min-width: 840px; }
    .bom-table th, .bom-table td { text-align: left; padding: 0.55rem 0.45rem; border-bottom: 1px solid #e2e8f0; }
    .bom-table th { font-size: 0.8rem; color: #64748b; font-weight: 600; background: #f8fafc; position: sticky; top: 0; }
    .bom-toggle-col { width: 36px; text-align: center; }
    .bom-toggle { border: 1px solid #cbd5e1; border-radius: 6px; width: 24px; height: 24px; cursor: pointer; color: #334155; background: #fff; }
    .bom-item-cell { font-weight: 600; white-space: nowrap; }

    .bom-table input, .bom-table select { width: 100%; min-width: 90px; border: 1px solid #cbd5e1; border-radius: 6px; padding: 0.25rem 0.35rem; }
    .bom-actions-cell { display: flex; gap: 0.35rem; align-items: center; }
    .bom-row-manual { background: #fffbeb; }
    .bom-add-row-panel, .bom-upload-panel { margin-top: 1rem; border: 1px solid #e2e8f0; border-radius: 10px; padding: 0.75rem; }
    .bom-add-row-form, .bom-upload-form { display: grid; grid-template-columns: repeat(7, minmax(0, 1fr)) auto; gap: 0.5rem; align-items: center; }
    .small-muted { color: #64748b; font-size: 0.85rem; margin-bottom: 0.4rem; }

    .sidebar-stack { display: grid; gap: 1rem; }
    .sidebar-card { padding: 1rem; }
    .meta-list { display: grid; gap: 0.8rem; margin: 0; }
    .meta-row dt { color: #64748b; font-size: 0.8rem; }
    .meta-row dd { margin: 0.2rem 0 0; font-weight: 600; }
    .quick-actions { display: grid; gap: 0.6rem; }

    @@media (max-width: 1080px) {
        .part-detail-grid { grid-template-columns: 1fr; }
        .overview-grid { grid-template-columns: 1fr; }
        .drawing-viewer-outer { height: 520px; }
        .drawing-frame { min-height: 520px; }
    }
</style>

<script>
    (() => {
        const root = document.querySelector('[data-part-tabs]');
        if (!root) return;

        const triggers = Array.from(root.querySelectorAll('[data-tab-target]'));
        const panes = Array.from(root.querySelectorAll('[data-tab-pane]'));

        const activate = (tabName) => {
            triggers.forEach((trigger) => {
                const isActive = trigger.dataset.tabTarget === tabName;
                trigger.classList.toggle('active', isActive);
                trigger.setAttribute('aria-selected', isActive.toString());
            });

            panes.forEach((pane) => {
                pane.classList.toggle('active', pane.dataset.tabPane === tabName);
            });
        };

        triggers.forEach((trigger) => {
            trigger.addEventListener('click', () => activate(trigger.dataset.tabTarget));
        });

        activate('overview');
    })();

    (() => {
        const toolbar = document.querySelector('[data-drawing-toolbar]');
        const viewport = document.querySelector('[data-drawing-viewport]');
        const scaled = document.querySelector('[data-drawing-scaled]');
        const levelLabel = document.querySelector('[data-zoom-level]');

        if (!toolbar || !viewport || !scaled || !levelLabel) return;

        const MIN_ZOOM = 0.5;
        const MAX_ZOOM = 2.5;
        const STEP = 0.1;
        let zoom = 1;

        const updateZoom = () => {
            scaled.style.transform = `scale(${zoom})`;
            scaled.style.width = `${100 / zoom}%`;
            levelLabel.textContent = `${Math.round(zoom * 100)}%`;
        };

        toolbar.querySelector('[data-zoom-in]')?.addEventListener('click', () => {
            zoom = Math.min(MAX_ZOOM, zoom + STEP);
            updateZoom();
        });

        toolbar.querySelector('[data-zoom-out]')?.addEventListener('click', () => {
            zoom = Math.max(MIN_ZOOM, zoom - STEP);
            updateZoom();
        });

        toolbar.querySelector('[data-zoom-reset]')?.addEventListener('click', () => {
            zoom = 1;
            viewport.scrollTop = 0;
            viewport.scrollLeft = 0;
            updateZoom();
        });

        updateZoom();
    })();

    (() => {
        const toggles = Array.from(document.querySelectorAll('[data-bom-toggle]'));
        if (toggles.length === 0) return;

        const setDescendantsVisibility = (rowId, visible) => {
            const descendants = Array.from(document.querySelectorAll(`[data-parent-id="${rowId}"]`));
            descendants.forEach((child) => {
                child.style.display = visible ? 'table-row' : 'none';
                if (!visible) {
                    const toggle = child.querySelector('[data-bom-toggle]');
                    if (toggle) {
                        toggle.setAttribute('aria-expanded', 'false');
                        toggle.textContent = '▸';
                    }
                    const childId = child.getAttribute('data-row-id');
                    if (childId) {
                        setDescendantsVisibility(childId, false);
                    }
                }
            });
        };

        toggles.forEach((toggle) => {
            toggle.addEventListener('click', () => {
                const rowId = toggle.getAttribute('data-target-id');
                if (!rowId) return;

                const expanded = toggle.getAttribute('aria-expanded') === 'true';
                toggle.setAttribute('aria-expanded', (!expanded).toString());
                toggle.textContent = expanded ? '▸' : '▾';
                setDescendantsVisibility(rowId, !expanded);
            });
        });
    })();
</script>
