@page "{itemNo}"
@model MTS.RazorStarter.Pages.Engineering.FramePartModel
@{
    ViewData["Title"] = $"Frame Part {Model.FramePart?.ItemNo}";
}

@if (Model.FramePart == null)
{
    <section class="part-empty-state">
        <h2>Part not found</h2>
        <p>The requested frame part is unavailable.</p>
    </section>
}
else
{
    <section class="part-detail-page">
        <partial name="PartComponents/_PartHeader" model="Model.FramePart" />

        <div class="part-detail-grid">
            <div class="part-main-column">
                <partial name="PartComponents/_PartTabs" model="Model.FramePart" />
            </div>
            <aside class="part-sidebar-column">
                <partial name="PartComponents/_SidebarPanel" model="Model.FramePart" />
            </aside>
        </div>
    </section>
}


<script>
    (() => {
        const root = document.querySelector('[data-part-tabs]');
        if (!root) return;

        const triggers = Array.from(root.querySelectorAll('[data-tab-target]'));
        const panes = Array.from(root.querySelectorAll('[data-tab-pane]'));

        const activate = (tabName) => {
            triggers.forEach((trigger) => {
                const isActive = trigger.dataset.tabTarget === tabName;
                trigger.classList.toggle('active', isActive);
                trigger.setAttribute('aria-selected', isActive.toString());
            });

            panes.forEach((pane) => {
                pane.classList.toggle('active', pane.dataset.tabPane === tabName);
            });
        };

        triggers.forEach((trigger) => {
            trigger.addEventListener('click', () => activate(trigger.dataset.tabTarget));
        });

        activate('overview');
    })();

    (() => {
        const toolbar = document.querySelector('[data-drawing-toolbar]');
        const viewport = document.querySelector('[data-drawing-viewport]');
        const scaled = document.querySelector('[data-drawing-scaled]');
        const levelLabel = document.querySelector('[data-zoom-level]');

        if (!toolbar || !viewport || !scaled || !levelLabel) return;

        const MIN_ZOOM = 0.5;
        const MAX_ZOOM = 2.5;
        const STEP = 0.1;
        let zoom = 1;

        const updateZoom = () => {
            scaled.style.transform = `scale(${zoom})`;
            scaled.style.width = `${100 / zoom}%`;
            levelLabel.textContent = `${Math.round(zoom * 100)}%`;
        };

        toolbar.querySelector('[data-zoom-in]')?.addEventListener('click', () => {
            zoom = Math.min(MAX_ZOOM, zoom + STEP);
            updateZoom();
        });

        toolbar.querySelector('[data-zoom-out]')?.addEventListener('click', () => {
            zoom = Math.max(MIN_ZOOM, zoom - STEP);
            updateZoom();
        });

        toolbar.querySelector('[data-zoom-reset]')?.addEventListener('click', () => {
            zoom = 1;
            viewport.scrollTop = 0;
            viewport.scrollLeft = 0;
            updateZoom();
        });

        updateZoom();
    })();

    (() => {
        const toggles = Array.from(document.querySelectorAll('[data-bom-toggle]'));
        if (toggles.length === 0) return;

        const setDescendantsVisibility = (rowId, visible) => {
            const descendants = Array.from(document.querySelectorAll(`[data-parent-id="${rowId}"]`));
            descendants.forEach((child) => {
                child.style.display = visible ? 'table-row' : 'none';
                if (!visible) {
                    const toggle = child.querySelector('[data-bom-toggle]');
                    if (toggle) {
                        toggle.setAttribute('aria-expanded', 'false');
                        toggle.textContent = '▸';
                    }
                    const childId = child.getAttribute('data-row-id');
                    if (childId) {
                        setDescendantsVisibility(childId, false);
                    }
                }
            });
        };

        toggles.forEach((toggle) => {
            toggle.addEventListener('click', () => {
                const rowId = toggle.getAttribute('data-target-id');
                if (!rowId) return;

                const expanded = toggle.getAttribute('aria-expanded') === 'true';
                toggle.setAttribute('aria-expanded', (!expanded).toString());
                toggle.textContent = expanded ? '▸' : '▾';
                setDescendantsVisibility(rowId, !expanded);
            });
        });
    })();
</script>
