@inject MTS.RazorStarter.Services.NavigationService Navigation
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MTS</title>
    <link rel="stylesheet" href="~/css/mts-theme.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">
        <aside class="sidebar">
            <div>
                <div class="brand">MTS</div>
                <div class="brand-subtitle">Manufacturing Tracking System</div>
            </div>
            <nav>
                <a class="nav-link" href="/Stations/Dashboard">Stations Dashboard</a>
                @foreach (var item in Navigation.GetPrimaryNav())
                {
                    <a class="nav-link" href="@item.Url">@item.Title</a>
                }
            </nav>
        </aside>
        <main class="content">
            <header class="topbar">
                <h1>@ViewData["Title"]</h1>
                <div class="topbar-note">Manufacturing Tracking System</div>
            </header>
            <section>
                @RenderBody()
                @RenderSection("Scripts", required: false)
            </section>
        </main>
    </div>
</body>
</html>
